<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Produit 1 -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#E8F5E9"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/produit1"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnProduit1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_acheter"/>
        </LinearLayout>

        <!-- Produit 2 -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#E3F2FD"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/produit2"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnProduit2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_acheter"/>
        </LinearLayout>

        <!-- Produit 3 -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#FFF3E0"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/produit3"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnProduit3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_acheter"/>
        </LinearLayout>

        <!-- Produit 4 -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#F3E5F5"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/produit4"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnProduit4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_acheter"/>
        </LinearLayout>

        <!-- Produit 5 -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#FCE4EC"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/produit5"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnProduit5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_acheter"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>